; BetterDesk NSIS Polish Translation
; Custom Tauri messages for Polish installer

LangString addOrReinstall ${LANG_POLISH} "Dodaj/Zainstaluj ponownie komponenty"
LangString alreadyInstalled ${LANG_POLISH} "Aplikacja jest już zainstalowana"
LangString alreadyInstalledLong ${LANG_POLISH} "${PRODUCTNAME} ${VERSION} jest już zainstalowana. Wybierz operację, którą chcesz wykonać, a następnie kliknij Dalej."
LangString appRunning ${LANG_POLISH} "${PRODUCTNAME} jest uruchomiona! Zamknij ją najpierw, a następnie spróbuj ponownie."
LangString appRunningOk498 ${LANG_POLISH} "${PRODUCTNAME} jest uruchomiona!$\nKliknij OK, aby ją zamknąć."
LangString asociar ${LANG_POLISH} "Powiązanie plików"
LangString cleanInstall ${LANG_POLISH} "Czysta instalacja (usuń poprzednią wersję)"
LangString chooseFolder ${LANG_POLISH} "Wybierz folder, w którym chcesz zainstalować ${PRODUCTNAME}:"
LangString clear ${LANG_POLISH} "Wyczyść"
LangString confirmQuit ${LANG_POLISH} "Czy na pewno chcesz zamknąć instalator ${PRODUCTNAME}?"
LangString copyFailed ${LANG_POLISH} "Nie udało się skopiować plików do folderu instalacyjnego. Spróbuj uruchomić instalator jako administrator."
LangString current ${LANG_POLISH} "bieżąca"
LangString deleteAll ${LANG_POLISH} "Usuń wszystko (łącznie z danymi użytkownika)"
LangString deleteAppData ${LANG_POLISH} "Usuń dane aplikacji"
LangString deleteAppDataOld ${LANG_POLISH} "Usuń dane aplikacji ze starszej instalacji"
LangString dontUninstall ${LANG_POLISH} "Nie odinstalowuj"
LangString dontUninstallDowngrade ${LANG_POLISH} "Nie odinstalowuj (obniżanie wersji bez odinstalowania jest wyłączone w tym instalatorze)"
LangString failedToKillApp ${LANG_POLISH} "Nie udało się zamknąć ${PRODUCTNAME}. Zamknij ją ręcznie i spróbuj ponownie."
LangString installingWebview2 ${LANG_POLISH} "Instalowanie WebView2..."
LangString newerVersionInstalled ${LANG_POLISH} "Nowsza wersja ${PRODUCTNAME} jest już zainstalowana! Nie zaleca się instalowania starszej wersji. Jeśli naprawdę chcesz zainstalować tę starszą wersję, lepiej najpierw odinstalować bieżącą wersję. Wybierz operację, którą chcesz wykonać, a następnie kliknij Dalej."
LangString older ${LANG_POLISH} "starsza"
LangString olderOrEqualVersion ${LANG_POLISH} "starsza lub równa"
LangString openFolder ${LANG_POLISH} "Otwórz folder instalacji"
LangString perMachine ${LANG_POLISH} "Dla wszystkich użytkowników"
LangString perUser ${LANG_POLISH} "Tylko dla bieżącego użytkownika"
LangString permissionRequired ${LANG_POLISH} "Wymagane uprawnienia administratora"
LangString readyToInstall ${LANG_POLISH} "Gotowe do instalacji!"
LangString reinstall ${LANG_POLISH} "Zainstaluj ponownie"
LangString reinstallHelp ${LANG_POLISH} "Odinstaluj istniejącą wersję i zainstaluj ponownie."
LangString removeOldVersion ${LANG_POLISH} "Usuń starszą wersję"
LangString restartApp ${LANG_POLISH} "Uruchom ${PRODUCTNAME}"
LangString startApp ${LANG_POLISH} "Uruchom ${PRODUCTNAME}"
LangString startMenu ${LANG_POLISH} "Menu Start"
LangString unableToUninstall ${LANG_POLISH} "Nie udało się odinstalować!"
LangString uninstallApp ${LANG_POLISH} "Odinstaluj ${PRODUCTNAME}"
LangString uninstallSuccess ${LANG_POLISH} "Odinstalowano pomyślnie!"
LangString updateMode ${LANG_POLISH} "Tryb aktualizacji"
LangString webview2AbortError ${LANG_POLISH} "Nie udało się zainstalować WebView2! Aplikacja nie może działać bez niego. Spróbuj zainstalować ręcznie lub uruchom instalator jako administrator."
LangString webview2DownloadError ${LANG_POLISH} "Błąd: Nie udało się pobrać WebView2 — $0"
LangString webview2DownloadSuccess ${LANG_POLISH} "Bootstrapper WebView2 pobrany pomyślnie"
LangString webview2Downloading ${LANG_POLISH} "Pobieranie WebView2 bootstrapper..."
LangString webview2InstallError ${LANG_POLISH} "Błąd: Instalacja WebView2 nie powiodła się z kodem: $1"
LangString webview2InstallSuccess ${LANG_POLISH} "WebView2 zainstalowano pomyślnie"

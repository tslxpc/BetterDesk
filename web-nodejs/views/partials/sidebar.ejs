<!-- Sidebar Navigation -->
<aside class="sidebar" id="sidebar">
    <!-- Sidebar Header -->
    <div class="sidebar-header">
        <a href="/" class="sidebar-logo">
            <% if (branding.logoType === 'svg' && branding.logoSvg) { %>
            <span class="sidebar-logo-svg"><%- branding.logoSvg %></span>
            <% } else if (branding.logoType === 'image' && branding.logoUrl) { %>
            <img src="<%= branding.logoUrl %>" alt="<%= appName %>" class="sidebar-logo-img">
            <% } else { %>
            <span class="material-icons"><%= branding.logoIcon || 'dns' %></span>
            <span class="sidebar-logo-text"><%= appName %></span>
            <% } %>
        </a>
    </div>
    
    <!-- Navigation -->
    <nav class="sidebar-nav">
        <!-- Main Section -->
        <div class="sidebar-section">
            <div class="sidebar-section-title"><%= _('nav.main') %></div>
            
            <a href="/" class="sidebar-link <%= currentPage === 'dashboard' ? 'active' : '' %>">
                <span class="material-icons">dashboard</span>
                <span class="sidebar-link-text"><%= _('nav.dashboard') %></span>
            </a>
            
            <a href="/devices" class="sidebar-link <%= currentPage === 'devices' ? 'active' : '' %>">
                <span class="material-icons">devices</span>
                <span class="sidebar-link-text"><%= _('nav.devices') %></span>
            </a>
            
            <a href="/registrations" class="sidebar-link <%= currentPage === 'registrations' ? 'active' : '' %>">
                <span class="material-icons">how_to_reg</span>
                <span class="sidebar-link-text"><%= _('nav.registrations') %></span>
                <span class="badge-sidebar" id="reg-sidebar-badge" style="display: none;">0</span>
            </a>
        </div>
        
        <!-- Management Section -->
        <div class="sidebar-section">
            <div class="sidebar-section-title"><%= _('nav.management') || 'Management' %></div>
            
            <a href="/inventory" class="sidebar-link <%= currentPage === 'inventory' ? 'active' : '' %>">
                <span class="material-icons">inventory_2</span>
                <span class="sidebar-link-text"><%= _('nav.inventory') %></span>
            </a>
            
            <a href="/tickets" class="sidebar-link <%= currentPage === 'tickets' ? 'active' : '' %>">
                <span class="material-icons">confirmation_number</span>
                <span class="sidebar-link-text"><%= _('nav.tickets') %></span>
            </a>

            <a href="/help-requests" class="sidebar-link <%= currentPage === 'help-requests' ? 'active' : '' %>">
                <span class="material-icons">support_agent</span>
                <span class="sidebar-link-text"><%= _('nav.help_requests') %></span>
            </a>
            
            <a href="/automation" class="sidebar-link <%= currentPage === 'automation' ? 'active' : '' %>">
                <span class="material-icons">smart_toy</span>
                <span class="sidebar-link-text"><%= _('nav.automation') %></span>
            </a>
            
            <a href="/network" class="sidebar-link <%= currentPage === 'network' ? 'active' : '' %>">
                <span class="material-icons">lan</span>
                <span class="sidebar-link-text"><%= _('nav.network') %></span>
            </a>
            
            <a href="/activity" class="sidebar-link <%= currentPage === 'activity' ? 'active' : '' %>">
                <span class="material-icons">timeline</span>
                <span class="sidebar-link-text"><%= _('nav.activity') %></span>
            </a>
            
            <a href="/cdap" class="sidebar-link <%= currentPage === 'cdap' ? 'active' : '' %>">
                <span class="material-icons">developer_board</span>
                <span class="sidebar-link-text"><%= _('nav.cdap') %></span>
            </a>
        </div>
        
        <!-- Tools Section -->
        <div class="sidebar-section">
            <div class="sidebar-section-title"><%= _('nav.tools') %></div>
            
            <a href="/reports" class="sidebar-link <%= currentPage === 'reports' ? 'active' : '' %>">
                <span class="material-icons">assessment</span>
                <span class="sidebar-link-text"><%= _('nav.reports') %></span>
            </a>
            
            <a href="/keys" class="sidebar-link <%= currentPage === 'keys' ? 'active' : '' %>">
                <span class="material-icons">vpn_key</span>
                <span class="sidebar-link-text"><%= _('nav.keys') %></span>
            </a>
            
            <a href="/generator" class="sidebar-link <%= currentPage === 'generator' ? 'active' : '' %>">
                <span class="material-icons">build</span>
                <span class="sidebar-link-text"><%= _('nav.generator') %></span>
            </a>
        </div>
        
        <!-- System Section -->
        <div class="sidebar-section">
            <div class="sidebar-section-title"><%= _('nav.system') %></div>
            
            <% if (user && user.role === 'admin') { %>
            <a href="/tokens" class="sidebar-link <%= currentPage === 'tokens' ? 'active' : '' %>">
                <span class="material-icons">token</span>
                <span class="sidebar-link-text"><%= _('nav.tokens') %></span>
            </a>
            
            <a href="/tenants" class="sidebar-link <%= currentPage === 'tenants' ? 'active' : '' %>">
                <span class="material-icons">business</span>
                <span class="sidebar-link-text"><%= _('nav.tenants') %></span>
            </a>

            <a href="/organizations" class="sidebar-link <%= currentPage === 'organizations' ? 'active' : '' %>">
                <span class="material-icons">corporate_fare</span>
                <span class="sidebar-link-text"><%= _('nav.organizations') %></span>
            </a>

            <a href="/dataguard" class="sidebar-link <%= currentPage === 'dataguard' ? 'active' : '' %>">
                <span class="material-icons">shield</span>
                <span class="sidebar-link-text"><%= _('nav.dataguard') %></span>
            </a>
            
            <a href="/users" class="sidebar-link <%= currentPage === 'users' ? 'active' : '' %>">
                <span class="material-icons">group</span>
                <span class="sidebar-link-text"><%= _('nav.users') %></span>
            </a>
            <% } %>
            
            <a href="/settings" class="sidebar-link <%= currentPage === 'settings' ? 'active' : '' %>">
                <span class="material-icons">settings</span>
                <span class="sidebar-link-text"><%= _('nav.settings') %></span>
            </a>
        </div>
    </nav>
    
    <!-- Sidebar Footer - User -->
    <div class="sidebar-footer">
        <div class="sidebar-user" id="user-menu-trigger">
            <div class="sidebar-user-avatar">
                <%= user && user.username ? user.username.charAt(0).toUpperCase() : 'A' %>
            </div>
            <div class="sidebar-user-info">
                <div class="sidebar-user-name"><%= user ? user.username : 'Admin' %></div>
                <div class="sidebar-user-role"><%= user ? user.role : 'administrator' %></div>
            </div>
        </div>
    </div>
</aside>
<script>
// Preserve sidebar scroll position across page navigations
(function() {
    var nav = document.querySelector('.sidebar-nav');
    if (!nav) return;
    var KEY = 'bd_sidebar_scroll';
    try {
        var saved = sessionStorage.getItem(KEY);
        if (saved) nav.scrollTop = parseInt(saved, 10) || 0;
    } catch(e) {}
    // Also scroll active link into view if not visible
    var active = nav.querySelector('.sidebar-link.active');
    if (active) {
        var rect = active.getBoundingClientRect();
        var navRect = nav.getBoundingClientRect();
        if (rect.top < navRect.top || rect.bottom > navRect.bottom) {
            active.scrollIntoView({ block: 'center' });
        }
    }
    // Save scroll on navigation
    window.addEventListener('beforeunload', function() {
        try { sessionStorage.setItem(KEY, String(nav.scrollTop)); } catch(e) {}
    });
})();
</script>

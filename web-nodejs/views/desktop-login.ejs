<!DOCTYPE html>
<html lang="<%= lang || 'en' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="<%= appName %> - Login">
    <meta name="robots" content="noindex, nofollow">
    <title><%= _('auth.login') %> - <%= appName %></title>
    
    <link rel="icon" type="image/svg+xml" href="/branding/favicon.svg">
    <link rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Icons">
    <link rel="stylesheet" href="/css/main.css?v=<%= cacheVersion %>">
    <link rel="stylesheet" href="/css/theme.css?v=<%= cacheVersion %>">
    <link rel="stylesheet" href="/css/desktop-login.css?v=<%= cacheVersion %>">
</head>
<body class="desktop-login-page">
    <!-- Wallpaper layer -->
    <div class="dl-wallpaper" id="dl-wallpaper">
        <div class="dl-wallpaper-overlay"></div>
    </div>

    <!-- Lock screen overlay (click/key to dismiss) -->
    <div class="dl-lock-screen active" id="dl-lock-screen">
        <div class="dl-lock-clock" id="dl-lock-clock">
            <div class="dl-lock-time" id="dl-lock-time"></div>
            <div class="dl-lock-date" id="dl-lock-date"></div>
        </div>
        <div class="dl-lock-hint"><%= _('desktop_login.click_to_sign_in') || 'Click anywhere or press a key to sign in' %></div>
    </div>

    <!-- Login form layer -->
    <div class="dl-login-layer" id="dl-login-layer">
        <!-- Multi-user selector (bottom-left) -->
        <div class="dl-users" id="dl-users"></div>

        <!-- Center login card -->
        <div class="dl-card-wrapper">
            <div class="dl-card" id="dl-card">
                <!-- Avatar -->
                <div class="dl-avatar" id="dl-avatar">
                    <span class="material-icons">person</span>
                </div>

                <!-- Username display (when user is pre-selected) -->
                <div class="dl-username-display hidden" id="dl-username-display"></div>

                <!-- Step 1: Credentials form -->
                <form class="dl-form" id="dl-login-form">
                    <div class="dl-field">
                        <input
                            type="text"
                            id="dl-username"
                            class="dl-input"
                            placeholder="<%= _('desktop_login.username_placeholder') || 'Username' %>"
                            autocomplete="username"
                            required
                            autofocus
                        >
                    </div>
                    <div class="dl-field">
                        <div class="dl-password-wrapper">
                            <input
                                type="password"
                                id="dl-password"
                                class="dl-input"
                                placeholder="<%= _('desktop_login.password_placeholder') || 'Password' %>"
                                autocomplete="current-password"
                                required
                            >
                            <button type="button" class="dl-password-toggle" id="dl-password-toggle">
                                <span class="material-icons">visibility</span>
                            </button>
                        </div>
                    </div>

                    <!-- Error message -->
                    <div class="dl-error hidden" id="dl-error">
                        <span class="material-icons">error</span>
                        <span id="dl-error-text"></span>
                    </div>

                    <button type="submit" class="dl-submit" id="dl-submit-btn">
                        <span class="dl-submit-text"><%= _('desktop_login.sign_in') || 'Sign in' %></span>
                        <span class="dl-submit-arrow"><span class="material-icons">arrow_forward</span></span>
                    </button>
                </form>

                <!-- Step 2: TOTP 2FA form (hidden by default) -->
                <form class="dl-form hidden" id="dl-totp-form">
                    <div class="dl-totp-header">
                        <span class="material-icons dl-totp-icon">security</span>
                        <div class="dl-totp-title"><%= _('desktop_login.totp_title') || 'Two-Factor Authentication' %></div>
                        <div class="dl-totp-subtitle"><%= _('desktop_login.totp_subtitle') || 'Enter the 6-digit code from your authenticator app' %></div>
                    </div>

                    <div class="dl-totp-inputs" id="dl-totp-inputs">
                        <input type="text" class="dl-totp-digit" maxlength="1" inputmode="numeric" pattern="[0-9]" data-idx="0" autofocus>
                        <input type="text" class="dl-totp-digit" maxlength="1" inputmode="numeric" pattern="[0-9]" data-idx="1">
                        <input type="text" class="dl-totp-digit" maxlength="1" inputmode="numeric" pattern="[0-9]" data-idx="2">
                        <span class="dl-totp-separator">–</span>
                        <input type="text" class="dl-totp-digit" maxlength="1" inputmode="numeric" pattern="[0-9]" data-idx="3">
                        <input type="text" class="dl-totp-digit" maxlength="1" inputmode="numeric" pattern="[0-9]" data-idx="4">
                        <input type="text" class="dl-totp-digit" maxlength="1" inputmode="numeric" pattern="[0-9]" data-idx="5">
                    </div>

                    <div class="dl-error hidden" id="dl-totp-error">
                        <span class="material-icons">error</span>
                        <span id="dl-totp-error-text"></span>
                    </div>

                    <button type="submit" class="dl-submit" id="dl-totp-submit">
                        <span class="dl-submit-text"><%= _('desktop_login.verify') || 'Verify' %></span>
                        <span class="dl-submit-arrow"><span class="material-icons">verified_user</span></span>
                    </button>

                    <div class="dl-totp-back">
                        <a href="#" id="dl-totp-back-link">
                            <span class="material-icons" style="font-size:16px">arrow_back</span>
                            <%= _('desktop_login.back_to_login') || 'Back to login' %>
                        </a>
                    </div>
                </form>
            </div>
        </div>

            <!-- Version footer -->
            <div class="dl-footer">
                <span><%= appName %> v<%= appVersion %></span>
            </div>
        </div>

        <!-- Session expired indicator (shown when redirected from session timeout) -->
        <script nonce="<%= cspNonce %>">
            window.BetterDesk = window.BetterDesk || {};
            window.BetterDesk.users = <%- JSON.stringify(loginUsers || []) %>;
            window.BetterDesk.csrfToken = '<%= csrfToken %>';
            // Detect session expiry: if we arrived from a non-login page, session expired
            if (document.referrer && !document.referrer.includes('/login')) {
                window.BetterDesk.sessionExpired = true;
            }
        </script>

    <script nonce="<%= cspNonce %>">
        window.BetterDesk = {
            csrfToken: '<%= csrfToken || "" %>',
            lang: '<%= lang || "en" %>',
            translations: <%- JSON.stringify(translations || {}) %>,
            branding: <%- JSON.stringify(branding || {}) %>,
            users: <%- JSON.stringify(loginUsers || []) %>
        };
    </script>
    <script src="/js/utils.js?v=<%= cacheVersion %>"></script>
    <script src="/js/desktop-login.js?v=<%= cacheVersion %>"></script>
</body>
</html>
